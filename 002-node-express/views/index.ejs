<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <title>002-node-express</title>
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="keywords" content="Express, Node.js, Web Development, OAuth">
        <meta name="description"
              content="A simple Express application for demonstrating OAuth">
        <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f4f4f4;
        }
        main { width: 80%; max-width: 400px; margin: 0 auto; }
        h1 { color: #333; }
        p { color: #666; }
        .env-banner {
            padding: 6px 16px;
            text-align: center;
            font-weight: bold;
            font-size: 0.85em;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }
        .env-banner--dev     { background-color: #003078; color: #ffffff; }
        .env-banner--staging { background-color: #f47738; color: #ffffff; }
        .env-banner--prod    { background-color: #00703c; color: #ffffff; }
        </style>
    </head>
    <body>
        <div class="env-banner env-banner--<%= environment %>"><%= environment %> environment</div>
        <main>
            <h1>Welcome</h1>
            <p>
                This is a simple Express application demonstrating OAuth, specifically for <a href="https://sso.service.security.gov.uk/">GOV.UK Internal Access</a>.
            </p>
            <p>
                For more information, visit the <a href="https://github.com/govuk-digital-backbone/internal-access-samples">github.com/govuk-digital-backbone/internal-access-samples</a>.
            </p>
            <% if (signed_in) { %>
                <p>You are signed in as <%= user.display_name %>.</p>
                <p>Your email is <%= user.email %>.</p>
                <% if (user.picture) { %>
                    <img src="<%= user.picture %>"
                         alt="Profile Picture"
                         height="100"
                         width="100">
                <% } %>
                <p>
                    <a href="/sign-out">Sign Out</a>
                </p>
            <% } else { %>
                <p>You are not signed in.</p>
                <p>
                    <a href="/sign-in">Sign In</a>
                </p>
            <% } %>
        </main>
    </body>
</html>
