    "compilerOptions": {
        "module": "nodenext",
        "target": "ESNext",
        "moduleResolution": "nodenext",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "skipLibCheck": true,
        "typeRoots": ["@types", "node_modules/@types"],
        
    }
